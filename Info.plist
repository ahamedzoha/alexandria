<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Self-hosted servers are often plain http:// on a LAN. Scope the ATS
		     exception to local networking (raw IPs, .local, unqualified names)
		     instead of disabling ATS globally; https to the internet stays
		     enforced. Plain http to a fully-qualified public hostname is
		     intentionally NOT allowed — use https (reverse proxy) for that. -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Sparkle auto-updates: the appcast is attached to every GitHub release,
	     and `latest/download` always serves the newest one. Updates are
	     EdDSA-signed by Scripts/package.sh (private key in the login Keychain;
	     generated by Sparkle's generate_keys). -->
	<key>SUFeedURL</key>
	<string>https://github.com/ahamedzoha/alexandria/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>XxVI3wBKcScuTYaxVooOgVc/R2AJyjDGmVTh1JOP2CI=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
</dict>
</plist>
